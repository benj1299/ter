    "# Generique Fourrier Descriptor\n",
    "# Argument : The opencv image, \n",
    "# Return : GFD Signature\n",
    "\n",
    "def GFD(image, m, n):\n",
    "    M, N = (image.shape[0], image.shape[1])\n",
    "    maxR = sqrt((((N)//2)**2) + (((N)//2)**2))\n",
    "    \n",
    "    x = np.linspace(-(N-1)//2, (N-1)//2, N)\n",
    "    y = np.linspace(-(M-1)//2, (M-1)//2, M)\n",
    "    X, Y = np.meshgrid(x, y)\n",
    "\n",
    "    radius = np.sqrt(np.power(X, 2) + np.power(Y, 2)) / maxR\n",
    "\n",
    "    theta = np.arctan2(Y, X)\n",
    "    theta[theta < 0] = theta[theta < 0] + (2 * np.pi)\n",
    "\n",
    "    FR = np.zeros((m,n))\n",
    "    FI = np.zeros((m,n))\n",
    "    FD = np.zeros((m*n,1))\n",
    "\n",
    "    for rad in range(m):\n",
    "        for i, ang in enumerate(range(n)):\n",
    "            tempR = image * (np.cos(2 * np.pi * rad * radius + ang * theta))\n",
    "            tempI = image * (np.sin(2 * np.pi * rad * radius + ang * theta))\n",
    "            FR[rad, ang] = np.sum(tempR)\n",
    "            FI[rad, ang] = np.sum(tempI) # Calculer seulement si c'est un pixel allumé\n",
    "            \n",
    "            if rad == 0 and ang == 0:\n",
    "                FD[i] = sqrt((2* (FR[0,0]**2))) / (np.pi * (maxR**2))\n",
    "            else:\n",
    "                FD[i] = sqrt((FR[rad, ang]**2) + (FI[rad, ang]**2)) / (sqrt((2* (FR[0,0]**2))))\n",
    "    return FD"
   ]
  },
